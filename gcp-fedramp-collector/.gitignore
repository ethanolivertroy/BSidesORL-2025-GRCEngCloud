# FedRAMP GCP Collector ignores
#
# Most generated files from this tool are cloud configuration evidence. Even
# when they do not contain secrets, they can describe a real environment and
# should not be committed by accident.

# Collection archives and extracted collector output
fedramp_gcp_collection_*/
fedramp_multi_collection_*/
collector_output/
raw_data/
processed_data/
client_data/
assessment_*/
audit_*/
scan_results/
*.tar.gz
*.zip

# Generated evidence and reports
*.json
*.csv
*.html
*.xlsx
reports/
analysis_output/
compliance_reports/
assessment_results/

# Local credentials and secrets
.env
.env.*
credentials/
secrets/
*-key.json
*_key.json
*.pem
*.key
*.cert
*.p12
*.pfx
*.kubeconfig

