__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST

